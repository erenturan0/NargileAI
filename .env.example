# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for Authentication
JWT_SECRET=nargile-ai-secret-key-2024

# Server Port (Cloud Run uses 8080)
PORT=8080

# Database Configuration (PostgreSQL / Cloud SQL)
# Local testing can use localhost:5432
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=nargile_ai

# For Cloud Run with Cloud SQL Auth Proxy (Unix Socket)
# DB_HOST=/cloudsql/your-project-id:your-region:your-instance-id
